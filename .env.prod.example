# DAKA Hlas — produkčné premenné. Skopíruj do .env a doplň hodnoty.
# Spustenie: docker compose -f docker-compose.prod.yml --env-file .env up -d --build

# Doména s automatickým HTTPS (napr. hlas.ckdaka.sk). Nechaj prázdne pre test cez http://IP
SITE_ADDRESS=hlas.ckdaka.sk

# OpenAI – povinné pre reálny prepis a zhrnutia (viď docs/NASADENIE.md ako získať)
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o

# Tajomstvá – nahraď náhodnými dlhými reťazcami (napr. `openssl rand -hex 32`)
JWT_SECRET=zmen-ma
JWT_REFRESH_SECRET=zmen-ma-tiez
POSTGRES_PASSWORD=zmen-ma-heslo-db
S3_ACCESS_KEY=daka
S3_SECRET_KEY=zmen-ma-heslo-storage

# Voliteľné: napojenie na CRM (webhook profilu klienta)
CRM_WEBHOOK_URL=
