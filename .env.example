# =====================================================================
# DAKA Hlas — vzor premenných prostredia. Skopíruj do .env a doplň hodnoty.
# Tajomstvá NIKDY necommituj.
# =====================================================================

# --- Databáza (PostgreSQL) ---
DATABASE_URL=postgresql://daka:daka@localhost:5432/daka_hlas?schema=public

# --- Fronta / cache (Redis) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (S3 / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_BUCKET=daka-hlas
S3_ACCESS_KEY=daka
S3_SECRET_KEY=daka-secret
S3_FORCE_PATH_STYLE=true

# --- Autentifikácia ---
JWT_SECRET=zmen-ma-na-nahodny-dlhy-retazec
JWT_REFRESH_SECRET=zmen-ma-na-iny-nahodny-dlhy-retazec
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- OpenAI (prepis + zhrnutia) ---
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o
AI_DEFAULT_LANGUAGE=sk

# --- CRM / rezervačný systém (outbound webhook) ---
# Ak nie je nastavené, profil klienta sa len pripraví (stub) a zaeviduje.
CRM_WEBHOOK_URL=
CRM_API_KEY=

# --- Aplikácia ---
API_PORT=4000
APP_BASE_URL=http://localhost:3000
DATA_REGION=eu

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
