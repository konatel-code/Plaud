{
  "name": "daka-hlas",
  "version": "0.1.0",
  "private": true,
  "description": "DAKA Hlas — AI hlasový asistent pre CK DAKA",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @daka/db generate",
    "db:migrate": "pnpm --filter @daka/db migrate",
    "db:seed": "pnpm --filter @daka/db seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "bcrypt"
    ]
  }
}
